{
  "name": "open-text-flow",
  "private": true,
  "version": "0.2.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "dist:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.opentextflow.app",
    "productName": "OpenTextFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/logo.ico",
        "to": "logo.ico"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico",
      "installerHeaderIcon": "public/logo.ico",
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.27.0",
    "axios": "^1.13.2",
    "docx-preview": "^0.3.7",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^3.4.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.29.0",
    "wait-on": "^8.0.5"
  }
}
